# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES CHECKLIST
# ==========================================
# Duplicate this file as .env and fill in the values for your deployment platform (Render, Vercel).

# ==========================================
# BACKEND CONFIGURATION (Render)
# ==========================================
NODE_ENV=production
PORT=5000

# Client Application URL (For CORS and redirect links)
FRONTEND_URL=https://hiremate-portal.vercel.app

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/database_name?retryWrites=true&w=majority

# Security (JWT)
JWT_ACCESS_SECRET=your_super_secret_access_key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key
JWT_REFRESH_EXPIRES_IN=7d

# File Uploads (Cloudinary)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Payments (Razorpay)
RAZORPAY_KEY=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_key_secret

# Emails (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM=no-reply@yourdomain.com

# AI / NVIDIA
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
MOCK_AI=false


# ==========================================
# FRONTEND CONFIGURATION (Vercel)
# ==========================================
# Note: In Vercel, prefix these with VITE_

VITE_API_URL=https://ai-powered-interview-hiring-platform.onrender.com/api/v1
VITE_SOCKET_URL=https://ai-powered-interview-hiring-platform.onrender.com
VITE_APP_NAME="AI-Powered Interview Platform"
VITE_CLOUDINARY_NAME=your_cloudinary_name
VITE_RAZORPAY_KEY=your_razorpay_key_id
