# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/ai-powered-interview-db

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_secure_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_secure_random_string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookies ──────────────────────────────────────────
COOKIE_SECURE=false

# ─── SMTP (Mailtrap for dev, SendGrid/Resend for prod) ─
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ai-powered-interview.com
# Email retry: max attempts for failed emails (default 3)
EMAIL_MAX_RETRIES=3
# Interview reminder: hours before interview to send reminder (default 24)
INTERVIEW_REMINDER_HOURS=24

# ─── NVIDIA NIM ───────────────────────────────────────
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ─── Razorpay ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Frontend (used by Docker build) ──────────────────
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000
